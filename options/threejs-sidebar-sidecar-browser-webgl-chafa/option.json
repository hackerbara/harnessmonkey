{
  "schemaVersion": 1,
  "kind": "option",
  "id": "threejs-sidebar-sidecar-browser-webgl-chafa",
  "label": "Three.js Sidebar Browser WebGL + Chafa Runtime",
  "description": "Enables the browser-backed WebGL sidecar with Chafa ANSI encoding, the high-fidelity 30fps renderer profile for threejs-sidebar-sidecar.",
  "requiresPackages": [
    "threejs-sidebar-sidecar"
  ],
  "option": {
    "argv": [],
    "env": {
      "CLAUDEMONKEY_THREE_SIDECAR_ENABLE": {
        "value": "1",
        "allowOverrideProcessEnv": true
      },
      "CLAUDEMONKEY_THREE_SIDECAR": {
        "value": "~/.harnessmonkey/patches/threejs-sidebar-sidecar/sidecar/browser-webgl/run-sidecar-browser-webgl.sh",
        "allowOverrideProcessEnv": true
      },
      "CLAUDEMONKEY_THREE_SIDECAR_RENDERER": {
        "value": "browser-webgl",
        "allowOverrideProcessEnv": true
      },
      "CLAUDEMONKEY_THREE_SIDECAR_SCENE": {
        "value": "browser-orbit-lab",
        "allowOverrideProcessEnv": true
      },
      "CLAUDEMONKEY_THREE_SIDECAR_ANSI": {
        "value": "chafa-vhalf",
        "allowOverrideProcessEnv": true
      },
      "CLAUDEMONKEY_THREE_SIDECAR_FPS": {
        "value": "30",
        "allowOverrideProcessEnv": true
      },
      "THREE_SIDECAR_CHAFA_BIN": {
        "value": "/opt/homebrew/bin/chafa",
        "allowOverrideProcessEnv": true
      },
      "THREE_SIDECAR_BROWSER_WEBGL_WINDOW_MODE": {
        "value": "offscreen",
        "allowOverrideProcessEnv": true
      }
    },
    "conflictsWithArgv": [],
    "conflictsWithOptions": [
      "threejs-sidebar-sidecar-local",
      "capybara-onsen-threejs-sidecar"
    ],
    "conflictsWithEnv": []
  }
}
